{
  "name": "charinavi",
  "type": "module",
  "version": "0.1.0",
  "description": "危険区域を考慮した自転車向け安全ルート計算ライブラリ",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepare": "pnpm run build",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@turf/turf": "^7.3.4"
  }
}
